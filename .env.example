# Copy this file to `.env.local` (or `.env`) and fill in values.
# Next.js loads `.env.local` automatically for local development.

# -----------------------------------------------------------------------------
# Database (PostgreSQL required — see prisma/schema.prisma)
# -----------------------------------------------------------------------------
# Local dev: point BOTH at the same Postgres URL (direct connection, no pooler).
#
# Example — Docker Postgres:
#   docker run --name pg-fx -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=fxtracker -p 5432:5432 -d postgres:16
#
# Then set both to the same connection string (required by Prisma schema).
# If you only define DATABASE_URL, the app copies it to DIRECT_URL at runtime for local dev.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"

# Supabase: use Transaction pooler for DATABASE_URL (often :6543) and Direct (:5432) for DIRECT_URL.
# DATABASE_URL="postgresql://..."
# DIRECT_URL="postgresql://..."

# -----------------------------------------------------------------------------
# Auth.js / NextAuth (required)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
AUTH_SECRET="paste-a-long-random-string-here"

# App URL — must match the port you use (this project defaults to 3004)
AUTH_URL="http://localhost:3004"

# Optional legacy alias (Auth.js prefers AUTH_URL)
# NEXTAUTH_URL="http://localhost:3004"

# -----------------------------------------------------------------------------
# Email (optional for local testing)
# -----------------------------------------------------------------------------
# Without Brevo, registration still succeeds but you may not receive mail.
# Verify the user manually: Prisma Studio → User → set emailVerified = true
# Or set BREVO_API_KEY and use a verified sender.
#
# BREVO_API_KEY=""
# BREVO_FROM_EMAIL="noreply@yourdomain.com"
# BREVO_FROM_NAME="FX Payment Tracker"
