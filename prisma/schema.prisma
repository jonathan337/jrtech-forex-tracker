generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

// Supabase: use the Transaction pooler URL for the app; use Direct connection for migrations.
// See: https://www.prisma.io/docs/guides/database/supabase
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  password                 String
  businessName             String
  defaultExchangeRate      Float     @default(6.7993)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  emailVerificationExpires DateTime?
  emailVerificationToken   String?
  emailVerified            Boolean   @default(false)
  people                   Person[]
}

model Person {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@index([userId])
}

model Card {
  id                     String                @id @default(cuid())
  personId               String
  cardNickname           String
  /** SCOTIABANK | REPUBLIC_BANK | FIRST_CITIZENS | RBC */
  issuingBank            String?
  lastFourDigits         String?
  notes                  String?
  alwaysAvailable        Boolean               @default(false)
  recurringAmountUSD     Float?
  recurringExchangeRate  Float?
  recurringPaymentDay    Int?
  recurringNotes         String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  person                 Person                @relation(fields: [personId], references: [id], onDelete: Cascade)
  monthlyAvailability    MonthlyAvailability[]
  usageEntries           CardUsage[]

  @@index([personId])
}

model CardUsage {
  id              String   @id @default(cuid())
  cardId          String
  year            Int
  month           Int
  amountUSD       Float
  /** USD paid back to the card owner for this usage (0 = still owed until you record payment). */
  paidToOwnerUSD  Float    @default(0)
  usageDate       DateTime @default(now())
  notes           String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, year, month])
}

model MonthlyAvailability {
  id           String   @id @default(cuid())
  cardId       String
  year         Int
  month        Int
  amountUSD    Float
  exchangeRate Float
  paymentDate  DateTime
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, year, month])
  @@index([year, month])
  @@index([cardId])
}
